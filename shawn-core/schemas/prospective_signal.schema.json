{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Prospective Resonance Signal",
  "type": "object",
  "required": [
    "id",
    "title",
    "registration_date",
    "review_date",
    "status",
    "information_cutoff",
    "primary_domain",
    "feature_scores",
    "unknown_features",
    "prediction_label",
    "confidence",
    "accuracy_result"
  ],
  "properties": {
    "id": {"type": "string"},
    "title": {"type": "string"},
    "registration_date": {"type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$"},
    "review_date": {"type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$"},
    "status": {"enum": ["open", "reviewed", "expired"]},
    "information_cutoff": {"type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$"},
    "primary_domain": {"type": "string"},
    "secondary_domains": {"type": "array", "items": {"type": "string"}},
    "first_visible_signal": {"type": "string"},
    "public_sources_available_at_cutoff": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["title", "date", "url", "why_it_matters"],
        "properties": {
          "title": {"type": "string"},
          "date": {"type": "string"},
          "url": {"type": "string"},
          "why_it_matters": {"type": "string"}
        }
      }
    },
    "feature_scores": {"type": "object", "additionalProperties": {"type": "number", "minimum": 0, "maximum": 1}},
    "unknown_features": {"type": "array", "items": {"type": "string"}},
    "prediction_label": {"enum": ["act", "bounded_act", "act_watch", "watch", "investigate", "pause", "ignore"]},
    "confidence": {"type": "number", "minimum": 0, "maximum": 1},
    "bounded_action": {"type": "string"},
    "one_thing_not_to_do": {"type": "string"},
    "what_would_change_label": {"type": "object"},
    "expected_review_question": {"type": "string"},
    "later_outcome": {"type": ["string", "null"]},
    "review_notes": {"type": "string"},
    "accuracy_result": {"enum": ["pending", "useful", "wrong", "mixed", "untestable"]}
  }
}
